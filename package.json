{
	"name": "kursor-cli",
	"version": "0.1.0",
	"description": "Toggle the CLI cursor",
	"keywords": [
		"toggle",
		"cli",
		"terminal",
		"cursor"
	],
	"repository": "https://github.com/hyperz111/kursor-cli.git",
	"license": "MIT",
	"author": "Hyper-Z11 (https://github.com/hyperz111)",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"format": "prettier -w .",
		"prepublishOnly": "pnpm run build",
		"test": "node --test",
		"types": "tsc --noEmit"
	},
	"dependencies": {
		"when-exit": "^2.1.5"
	},
	"devDependencies": {
		"@hyperz111/prettier-config": "^1.1.0",
		"@hyperz111/tsconfig": "^1.0.0",
		"@types/node": "^25.1.0",
		"cli-cursor": "^5.0.0",
		"prettier": "^3.6.2",
		"typescript": "^5.9.2"
	},
	"packageManager": "pnpm@10.15.0"
}
